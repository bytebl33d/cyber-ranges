[default]
; Note: ansible_host *MUST* be an IPv4 address or setting things like DNS
; servers will break.
; ------------------------------------------------
; puppet.lab
; ------------------------------------------------
dc01 ansible_host={{ip_range}}.10 dns_domain=dc01 dns_domain=dc01 dict_key=dc01
file01 ansible_host={{ip_range}}.50 dns_domain=dc01 dict_key=file01
pm01 ansible_host={{ip_range}}.200 dns_domain=dc01 dict_key=pm01

[all:vars]
ip_range=10.4.10
force_dns_server=no
dns_server={{ip_range}}.254

dns_server_forwarder={{ip_range}}.254

ansible_user=localuser
ansible_password=password

[linux:vars]
ansible_connection=ssh
ansible_port=22
ansible_user=debian
ansible_password=debian
ansible_ssh_pass=debian

[puppet_master]
pm01 ansible_host={{ip_range}}.200 dns_domain=dc01 dict_key=pm01


